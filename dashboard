function renderRanking() {
  const d = DATA[state.year];
  const list = d[state.arq];
  const titleMap = {
    general: 'Ranking general',
    inventor: 'Arquetipo Inventores',
    rebelde: 'Arquetipo Rebeldes',
    visionario: 'Arquetipo Visionarios',
    heroe: 'Arquetipo Héroes'
  };
  document.getElementById('sec-title').innerHTML = `${titleMap[state.arq]} <em>${state.year}</em>`;

  const area = document.getElementById('ranking-area');

  if (!list) {
    document.getElementById('sec-meta').textContent = '';
    area.innerHTML = `
      <div class="empty-state anim">
        <h3>Datos no disponibles</h3>
        <p>El Top 10 del arquetipo ${titleMap[state.arq].toLowerCase().replace('arquetipo ', '')} para 2024 no fue publicado en formato consultable por la fuente original.</p>
      </div>
    `;
    return;
  }

  const isGeneral = state.arq === 'general';
  document.getElementById('sec-meta').textContent = `${list.length} empresas · click para ver proyecto`;

  const html = list.map((row, i) => {
    let num, name, meta, hasCard;
    if (isGeneral) {
      const [n, nm, dept, sector] = row;
      num = n; name = nm;
      meta = [dept, sector].filter(x => x).join(' · ');
    } else {
      const [n, nm, project] = row;
      num = n; name = nm;
      meta = project || 'Proyecto no disponible';
    }
    hasCard = !!d.projects[name];
    const rankClass = num === 1 ? 'top1' : num <= 3 ? 'top3' : '';
    return `
      <div class="rank-row ${rankClass} ${hasCard ? 'has-card' : ''} anim" style="animation-delay:${i*0.015}s" data-empresa="${name}">
        <div class="rank-num">${num.toString().padStart(2,'0')}</div>
        <div>
          <div class="rank-name">${name}</div>
          ${meta ? `<div class="rank-meta">${meta}</div>` : ''}
        </div>
        ${hasCard ? '<div class="rank-tag proj">Proyecto</div>' : (isGeneral ? '<div class="rank-tag">—</div>' : '')}
      </div>
    `;
  }).join('');

  area.innerHTML = `<div class="ranking">${html}</div>`;

  // attach click handlers
  area.querySelectorAll('.rank-row.has-card').forEach(row => {
    row.addEventListener('click', () => {
      const name = row.dataset.empresa;
      renderProjectCard(name);
    });
