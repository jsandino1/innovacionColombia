    { label: 'Empresas evaluadas', value: d.submitted, sub: d.edition },
    { label: '% ventas en CTI', value: d.cti_pct, unit: '%', sub: 'Inversión promedio' },
    { label: 'Personas en innovación', value: d.people.toLocaleString('es-CO'), sub: 'Talento dedicado' },
    { label: 'Proyectos de innovación', value: d.projects_count.toLocaleString('es-CO'), sub: 'En el último año' },
    { label: '% ventas innovadoras', value: d.sales_innov_pct, unit: '%', sub: 'Ver nota', tip: tip },
    { label: 'Spin-offs creadas', value: d.spinoffs ?? '—', sub: d.spinoffs ? 'Nuevas empresas' : 'No reportado' }
  ];
  const html = kpis.map(k => `
    <div class="kpi ${k.tip ? 'has-tip' : ''}">
      <div class="kpi-label">${k.label}</div>
