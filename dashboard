<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Ranking Innovación Colombia · ANDI-Dinero 2024-2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter+Tight:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f5f1e8;
    --bg-card: #ffffff;
    --bg-soft: #ede5d3;
    --ink: #1a1612;
    --ink-soft: #4a3f31;
    --ink-mute: #8a7a63;
    --line: #d9cdb3;
    --line-soft: #ebe0c8;
    --gold: #c89b3c;
    --gold-deep: #8a6a1f;
    --gold-soft: #f4e8c8;
    --accent-1: #2d5f4e;   /* inventores */
    --accent-2: #b8423a;   /* rebeldes */
    --accent-3: #c89b3c;   /* visionarios */
    --accent-4: #6b4e8c;   /* héroes */
    --accent-general: #1a1612;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: var(--bg); color: var(--ink); font-family: 'Inter Tight', sans-serif; -webkit-font-smoothing: antialiased; }
  body {
    background-image:
      radial-gradient(circle at 0% 0%, rgba(200,155,60,0.08), transparent 40%),
      radial-gradient(circle at 100% 100%, rgba(45,95,78,0.06), transparent 50%);
    min-height: 100vh;
  }
  .wrap { max-width: 1280px; margin: 0 auto; padding: 32px 28px 80px; }

  /* ============ HEADER ============ */
  .masthead {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: end;
    gap: 24px;
    padding-bottom: 18px;
    border-bottom: 2px solid var(--ink);
    margin-bottom: 4px;
  }
  .mast-mark {
    font-family: 'Fraunces', serif;
    font-weight: 900;
    font-size: 14px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--bg);
    padding: 8px 12px;
    border-radius: 2px;
  }
  .mast-meta { font-size: 11px; color: var(--ink-mute); letter-spacing: 0.12em; text-transform: uppercase; text-align: right; line-height: 1.6; }
  .mast-issue { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--ink-soft); }

  .hero {
    padding: 36px 0 28px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 28px;
  }
  .hero h1 {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: clamp(40px, 6vw, 76px);
    line-height: 0.96;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 14px;
  }
  .hero h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--gold-deep);
  }
  .hero p {
    font-family: 'Fraunces', serif;
    font-size: 18px;
    color: var(--ink-soft);
    max-width: 720px;
    line-height: 1.5;
    font-weight: 300;
  }

  /* ============ YEAR SELECTOR ============ */
  .year-bar {
    display: flex;
    gap: 0;
    margin-bottom: 32px;
    border: 1.5px solid var(--ink);
    background: var(--bg-card);
    overflow: hidden;
  }
  .year-btn {
    flex: 1;
    background: transparent;
    border: none;
    padding: 18px 24px;
    cursor: pointer;
    font-family: 'Fraunces', serif;
    font-size: 28px;
    font-weight: 500;
    color: var(--ink-mute);
    letter-spacing: -0.01em;
    transition: all 0.18s ease;
    border-right: 1px solid var(--line);
    position: relative;
  }
  .year-btn:last-child { border-right: none; }
  .year-btn:hover { background: var(--bg-soft); color: var(--ink); }
  .year-btn.active {
    background: var(--ink);
    color: var(--bg);
  }
  .year-btn .yr-edition {
    display: block;
    font-family: 'Inter Tight', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.65;
    margin-top: 2px;
  }

  /* ============ KPI STRIP ============ */
  .kpi-strip {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    margin-bottom: 36px;
  }
  .kpi {
    background: var(--bg-card);
    padding: 20px 18px;
    position: relative;
  }
  .kpi-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-mute);
    font-weight: 600;
    margin-bottom: 10px;
    line-height: 1.3;
  }
  .kpi-value {
    font-family: 'Fraunces', serif;
    font-size: 34px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .kpi-value .unit { font-size: 16px; color: var(--ink-mute); margin-left: 2px; font-weight: 400; }
  .kpi-sub { font-size: 11px; color: var(--ink-mute); margin-top: 6px; font-family: 'JetBrains Mono', monospace; }
  .kpi.has-tip { cursor: help; }
  .kpi.has-tip::after {
    content: "ⓘ";
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 11px;
    color: var(--gold-deep);
  }
  .kpi.has-tip:hover .kpi-tip { display: block; }
  .kpi-tip {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    width: 280px;
    background: var(--ink);
    color: var(--bg);
    padding: 12px 14px;
    font-size: 12px;
    line-height: 1.5;
    z-index: 10;
    border-radius: 2px;
    font-family: 'Inter Tight', sans-serif;
    font-weight: 400;
  }
  .kpi-tip::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: var(--ink);
  }

  /* ============ ARQUETIPO TABS ============ */
  .arq-bar {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 20px;
    align-items: center;
  }
  .arq-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-mute);
    font-weight: 600;
    margin-right: 8px;
  }
  .arq-btn {
    background: var(--bg-card);
    border: 1px solid var(--line);
    padding: 9px 16px;
    cursor: pointer;
    font-family: 'Inter Tight', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-soft);
    letter-spacing: 0.02em;
    transition: all 0.15s ease;
    border-radius: 999px;
  }
  .arq-btn:hover { border-color: var(--ink); color: var(--ink); }
  .arq-btn.active {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--bg);
  }
  .arq-btn .dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    margin-right: 7px;
    vertical-align: middle;
    background: var(--ink-mute);
  }
  .arq-btn.active .dot { background: var(--bg) !important; }
  .arq-btn[data-arq="inventor"] .dot { background: var(--accent-1); }
  .arq-btn[data-arq="rebelde"] .dot { background: var(--accent-2); }
  .arq-btn[data-arq="visionario"] .dot { background: var(--accent-3); }
  .arq-btn[data-arq="heroe"] .dot { background: var(--accent-4); }

  /* ============ MAIN CONTENT ============ */
  .main-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 32px;
    margin-bottom: 48px;
  }
  @media (max-width: 900px) {
    .main-grid { grid-template-columns: 1fr; }
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 14px;
    border-bottom: 1.5px solid var(--ink);
    padding-bottom: 8px;
  }
  .section-title {
    font-family: 'Fraunces', serif;
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .section-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--gold-deep);
  }
  .section-meta {
    font-size: 11px;
    color: var(--ink-mute);
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.05em;
  }

  /* ============ RANKING TABLE ============ */
  .ranking {
    background: var(--bg-card);
    border: 1px solid var(--line);
  }
  .rank-row {
    display: grid;
    grid-template-columns: 48px 1fr auto;
    align-items: center;
    padding: 14px 18px;
    border-bottom: 1px solid var(--line-soft);
    cursor: pointer;
    transition: background 0.12s ease;
    position: relative;
  }
  .rank-row:last-child { border-bottom: none; }
  .rank-row:hover { background: var(--bg-soft); }
  .rank-row.has-card::after {
    content: "→";
    position: absolute;
    right: 18px;
    color: var(--gold-deep);
    font-size: 18px;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .rank-row.has-card:hover::after { opacity: 1; }
  .rank-row.has-card:hover .rank-tag { padding-right: 18px; }

  .rank-num {
    font-family: 'Fraunces', serif;
    font-size: 24px;
    font-weight: 500;
    color: var(--ink-mute);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .rank-row.top3 .rank-num { color: var(--gold-deep); font-weight: 700; }
  .rank-row.top1 .rank-num {
    background: var(--ink);
    color: var(--bg);
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
    font-size: 16px;
  }
  .rank-name {
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
  }
  .rank-meta {
    font-size: 11px;
    color: var(--ink-mute);
    margin-top: 2px;
    font-family: 'JetBrains Mono', monospace;
  }
  .rank-tag {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-mute);
    padding: 4px 8px;
    border: 1px solid var(--line);
    border-radius: 2px;
    transition: padding 0.15s ease;
  }
  .rank-tag.proj { color: var(--gold-deep); border-color: var(--gold); background: var(--gold-soft); }

  .empty-state {
    background: var(--bg-card);
    border: 1px dashed var(--line);
    padding: 60px 30px;
    text-align: center;
  }
  .empty-state h3 {
    font-family: 'Fraunces', serif;
    font-size: 22px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .empty-state p { color: var(--ink-mute); font-size: 14px; max-width: 380px; margin: 0 auto; }

  /* ============ SIDE PANEL: PROJECT CARD ============ */
  .side-panel {
    position: sticky;
    top: 20px;
    align-self: start;
  }
  .proj-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    padding: 24px;
    position: relative;
    overflow: hidden;
  }
  .proj-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 4px;
    background: var(--gold);
  }
  .proj-empty {
    color: var(--ink-mute);
    text-align: center;
    padding: 30px 10px;
    font-size: 13px;
    line-height: 1.6;
    font-family: 'Fraunces', serif;
    font-style: italic;
  }
  .proj-empty .icon {
    font-size: 28px;
    margin-bottom: 12px;
    opacity: 0.4;
    display: block;
  }
  .proj-eyebrow {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--gold-deep);
    font-weight: 600;
    margin-bottom: 10px;
  }
  .proj-company {
    font-family: 'Fraunces', serif;
    font-size: 26px;
    font-weight: 600;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 14px;
    letter-spacing: -0.01em;
  }
  .proj-stats {
    display: flex;
    gap: 14px;
    padding: 12px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .proj-stat { font-size: 11px; }
  .proj-stat-label { color: var(--ink-mute); text-transform: uppercase; letter-spacing: 0.08em; font-size: 9px; font-weight: 600; }
  .proj-stat-val { color: var(--ink); font-weight: 500; font-family: 'JetBrains Mono', monospace; margin-top: 2px; }
  .proj-title {
    font-family: 'Fraunces', serif;
    font-size: 17px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.35;
    margin-bottom: 8px;
  }
  .proj-desc {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink-soft);
    font-family: 'Fraunces', serif;
    font-weight: 300;
  }
  .proj-source {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--line-soft);
    font-size: 10px;
    color: var(--ink-mute);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  /* ============ COMPARATIVE SECTION ============ */
  .comp-section {
    margin-top: 60px;
    padding-top: 36px;
    border-top: 2px solid var(--ink);
  }
  .comp-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .comp-head h2 {
    font-family: 'Fraunces', serif;
    font-size: 36px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
    max-width: 600px;
  }
  .comp-head h2 em { font-style: italic; font-weight: 400; color: var(--gold-deep); }

  .comp-toggle {
    display: inline-flex;
    background: var(--bg-card);
    border: 1.5px solid var(--ink);
    padding: 0;
    border-radius: 999px;
    overflow: hidden;
  }
  .comp-toggle button {
    background: transparent;
    border: none;
    padding: 10px 22px;
    font-family: 'Inter Tight', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-soft);
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .comp-toggle button.active {
    background: var(--ink);
    color: var(--bg);
  }

  /* Consistency view */
  .consistency-table {
    background: var(--bg-card);
    border: 1px solid var(--line);
    overflow-x: auto;
  }
  .consistency-table table { width: 100%; border-collapse: collapse; }
  .consistency-table th, .consistency-table td {
    padding: 12px 14px;
    text-align: left;
    border-bottom: 1px solid var(--line-soft);
    font-size: 13px;
  }
  .consistency-table th {
    background: var(--bg-soft);
    font-family: 'Inter Tight', sans-serif;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-soft);
    font-weight: 600;
    position: sticky;
    top: 0;
  }
  .consistency-table td.empresa { font-weight: 500; color: var(--ink); }
  .consistency-table td.pos {
    font-family: 'JetBrains Mono', monospace;
    font-variant-numeric: tabular-nums;
    text-align: center;
    width: 80px;
  }
  .consistency-table td.pos .dot-pos {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px; height: 28px;
    border-radius: 50%;
    font-weight: 600;
    font-size: 12px;
  }
  .consistency-table td.pos.absent { color: var(--ink-mute); }
  .consistency-table td.pos.absent .dot-pos { background: var(--bg-soft); color: var(--ink-mute); }
  .consistency-table td.pos.top10 .dot-pos { background: var(--gold-soft); color: var(--gold-deep); }
  .consistency-table td.pos.top5 .dot-pos { background: var(--gold); color: white; }
  .consistency-table td.pos.top1 .dot-pos { background: var(--ink); color: var(--bg); }
  .consistency-table td.trend {
    width: 60px;
    text-align: center;
    font-size: 18px;
  }
  .trend-up { color: var(--accent-1); }
  .trend-down { color: var(--accent-2); }
  .trend-flat { color: var(--ink-mute); }

  /* Movement view */
  .movement-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  @media (max-width: 700px) { .movement-grid { grid-template-columns: 1fr; } }
  .mov-col h3 {
    font-family: 'Fraunces', serif;
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 14px;
    color: var(--ink);
  }
  .mov-col.gain h3 em { color: var(--accent-1); font-style: normal; }
  .mov-col.loss h3 em { color: var(--accent-2); font-style: normal; }
  .mov-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    padding: 12px 16px;
    background: var(--bg-card);
    border: 1px solid var(--line);
    margin-bottom: 6px;
    align-items: center;
  }
  .mov-name { font-weight: 500; font-size: 14px; }
  .mov-change {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--ink-mute);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .mov-change strong {
    font-family: 'Fraunces', serif;
    font-size: 18px;
    font-weight: 600;
  }
  .gain .mov-change strong { color: var(--accent-1); }
  .loss .mov-change strong { color: var(--accent-2); }

  /* ============ EVOLUTION CHART ============ */
  .evo-section {
    margin-top: 60px;
    padding-top: 36px;
    border-top: 2px solid var(--ink);
  }
  .evo-head { margin-bottom: 24px; }
  .evo-head h2 {
    font-family: 'Fraunces', serif;
    font-size: 36px;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .evo-head h2 em { font-style: italic; font-weight: 400; color: var(--gold-deep); }
  .evo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  @media (max-width: 700px) { .evo-grid { grid-template-columns: 1fr; } }
  .evo-card {
    background: var(--bg-card);
    padding: 24px 20px;
  }
  .evo-card h4 {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-mute);
    font-weight: 600;
    margin-bottom: 18px;
  }
  .evo-bars {
    display: flex;
    align-items: end;
    gap: 18px;
    height: 140px;
    margin-bottom: 16px;
    border-bottom: 1px solid var(--line);
    padding-bottom: 8px;
  }
  .evo-bar {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: end;
    gap: 6px;
    position: relative;
  }
  .evo-bar .bar {
    width: 100%;
    background: var(--gold);
    border-radius: 2px 2px 0 0;
    min-height: 3px;
    position: relative;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .evo-bar:nth-child(1) .bar { background: var(--ink-mute); }
  .evo-bar:nth-child(2) .bar { background: var(--gold); }
  .evo-bar:nth-child(3) .bar { background: var(--ink); }
  .evo-bar .val {
    position: absolute;
    top: -22px;
    font-family: 'Fraunces', serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    white-space: nowrap;
  }
  .evo-bar .yr {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--ink-mute);
  }

  /* ============ FOOTER ============ */
  footer {
    margin-top: 60px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    font-size: 11px;
    color: var(--ink-mute);
    line-height: 1.7;
  }
  footer strong { color: var(--ink-soft); font-weight: 600; }
  .sources {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    margin-top: 12px;
  }
  @media (max-width: 700px) { .sources { grid-template-columns: 1fr; } }
  .sources a {
    background: var(--bg-card);
    padding: 14px 16px;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 12px;
    transition: background 0.15s ease;
    position: relative;
  }
  .sources a:hover { background: var(--gold-soft); }
  .src-year {
    font-family: 'Fraunces', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--gold-deep);
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }
  .src-label {
    font-size: 12px;
    color: var(--ink-soft);
    line-height: 1.35;
    flex: 1;
    font-weight: 500;
  }
  .src-arrow {
    font-size: 14px;
    color: var(--ink-mute);
