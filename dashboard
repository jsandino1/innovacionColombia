          <div class="proj-stat-val">${arq}</div>
        </div>
      </div>
      <div class="proj-title">${proj.title}</div>
      <div class="proj-desc">${proj.desc}</div>
      <div class="proj-source">Fuente: Semana · ANDI · Dinero</div>
    </div>
  `;
}

// ========================================
// COMPARATIVE
// ========================================
function buildIndexByYear() {
  const idx = { 2024: {}, 2025: {}, 2026: {} };
  [2024, 2025, 2026].forEach(y => {
    DATA[y].general.forEach(r => {
      idx[y][normalizeName(r[1])] = r[0];
    });
  });
  return idx;
}

function normalizeName(name) {
  // normalize for cross-year matching
  let n = name.toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '') // remove accents
    .replace(/s\.?a\.?s?\.?$/i, '')
    .replace(/\s*\(.*?\)\s*/g, ' ')
    .replace(/[.,]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
  // aliases
  const aliases = {
    'fundacion cardioinfantil-lacardio': 'lacardio',
    'fundacion cardioinfantil lacardio': 'lacardio',
    'lacardio': 'lacardio',
    'banco davivienda': 'davivienda',
    'davivienda': 'davivienda',
    'renault-sofasa': 'renault sofasa',
    'renault sofasa': 'renault sofasa',
    'isa y sus empresas': 'isa',
    'promigas s a e s p': 'promigas',
    'promigas s a': 'promigas',
    'promigas': 'promigas',
    'gases de occidente': 'gases de occidente',
    'gases de occidente gdo': 'gases de occidente',
    'fundacion valle del lili': 'valle del lili',
    'fundacion valle de lili': 'valle del lili',
    'essity': 'essity',
    'essity anteriormente grupo familia': 'essity',
    'grupo familia': 'essity',
    'crystal': 'crystal',
    'corona industrial': 'corona industrial'
  };
  return aliases[n] || n;
}

function renderComparative() {
  const area = document.getElementById('comp-area');
  if (state.comp === 'consistency') {
    renderConsistency(area);
  } else {
    renderMovement(area);
  }
}

function renderConsistency(area) {
  const idx = buildIndexByYear();
  const allNames = new Set();
  [2024, 2025, 2026].forEach(y => {
    Object.keys(idx[y]).forEach(n => allNames.add(n));
  });

  // collect with display name
  const displayName = {};
  [2026, 2025, 2024].forEach(y => {  // prefer 2026 as canonical
    DATA[y].general.forEach(r => {
      const k = normalizeName(r[1]);
      if (!displayName[k]) displayName[k] = r[1];
    });
  });

  // rows: appearance count + best avg position
  const rows = [...allNames].map(n => {
    const p24 = idx[2024][n] || null;
    const p25 = idx[2025][n] || null;
    const p26 = idx[2026][n] || null;
    const appears = [p24, p25, p26].filter(Boolean).length;
    const positions = [p24, p25, p26].filter(Boolean);
    const avg = positions.reduce((a, b) => a + b, 0) / positions.length;
    return { name: displayName[n] || n, p24, p25, p26, appears, avg };
  });

  // only show those in 3 years, sorted by avg
  const triple = rows.filter(r => r.appears === 3).sort((a, b) => a.avg - b.avg);
  const double = rows.filter(r => r.appears === 2).sort((a, b) => a.avg - b.avg);

  const posCell = (p) => {
    if (!p) return `<td class="pos absent"><span class="dot-pos">—</span></td>`;
    const cls = p === 1 ? 'top1' : p <= 5 ? 'top5' : p <= 10 ? 'top10' : '';
    return `<td class="pos ${cls}"><span class="dot-pos">${p}</span></td>`;
  };

  const trend = (r) => {
    if (!r.p24 || !r.p26) return '<span class="trend-flat">—</span>';
    const delta = r.p24 - r.p26;
    if (delta > 0) return `<span class="trend-up">↑</span>`;
    if (delta < 0) return `<span class="trend-down">↓</span>`;
    return `<span class="trend-flat">=</span>`;
  };

  const tripleRows = triple.map(r => `
    <tr>
      <td class="empresa">${r.name}</td>
      ${posCell(r.p24)}${posCell(r.p25)}${posCell(r.p26)}
      <td class="trend">${trend(r)}</td>
    </tr>
  `).join('');

  const doubleRows = double.map(r => `
    <tr>
      <td class="empresa">${r.name}</td>
      ${posCell(r.p24)}${posCell(r.p25)}${posCell(r.p26)}
      <td class="trend">${trend(r)}</td>
    </tr>
  `).join('');

  area.innerHTML = `
    <div class="anim">
      <p style="color:var(--ink-mute); font-size:13px; margin-bottom:18px; max-width:680px; line-height:1.5; font-family:'Fraunces',serif; font-style:italic;">
        Empresas que aparecen en los tres rankings generales (Top 30) son la <strong style="color:var(--ink); font-style:normal;">columna vertebral</strong> del ecosistema de innovación colombiano. Las que aparecen en dos rankings son segundo anillo.
      </p>
      <div class="consistency-table">
        <table>
          <thead>
            <tr>
              <th style="width:auto;">Empresa</th>
              <th style="text-align:center;">2024</th>
              <th style="text-align:center;">2025</th>
              <th style="text-align:center;">2026</th>
              <th style="text-align:center;">24→26</th>
            </tr>
          </thead>
          <tbody>
            <tr><td colspan="5" style="background:var(--bg-soft); font-weight:600; font-size:11px; text-transform:uppercase; letter-spacing:0.12em; color:var(--ink-soft); padding:8px 14px;">Presentes los 3 años (${triple.length})</td></tr>
            ${tripleRows}
            <tr><td colspan="5" style="background:var(--bg-soft); font-weight:600; font-size:11px; text-transform:uppercase; letter-spacing:0.12em; color:var(--ink-soft); padding:8px 14px;">Presentes en 2 años (${double.length})</td></tr>
            ${doubleRows}
          </tbody>
        </table>
      </div>
    </div>
  `;
}

function renderMovement(area) {
  const idx = buildIndexByYear();
  const allNames = new Set();
  [2024, 2025, 2026].forEach(y => {
    Object.keys(idx[y]).forEach(n => allNames.add(n));
  });

  const displayName = {};
  [2026, 2025, 2024].forEach(y => {
    DATA[y].general.forEach(r => {
      const k = normalizeName(r[1]);
      if (!displayName[k]) displayName[k] = r[1];
    });
  });

  // movements: 24→25, 25→26, 24→26
  const moves = [];
  allNames.forEach(n => {
    const p24 = idx[2024][n] || null;
    const p25 = idx[2025][n] || null;
    const p26 = idx[2026][n] || null;
    const name = displayName[n] || n;
    if (p24 && p26) {
      moves.push({ name, from: p24, to: p26, delta: p24 - p26, span: '2024→2026' });
    } else if (p25 && p26) {
      moves.push({ name, from: p25, to: p26, delta: p25 - p26, span: '2025→2026' });
    }
  });

  const gainers = moves.filter(m => m.delta > 0).sort((a, b) => b.delta - a.delta).slice(0, 8);
  const losers = moves.filter(m => m.delta < 0).sort((a, b) => a.delta - b.delta).slice(0, 8);

  // new entries in 2026 (not in 24 or 25)
  const newcomers = [];
  DATA[2026].general.forEach(r => {
    const k = normalizeName(r[1]);
    if (!idx[2024][k] && !idx[2025][k]) {
      newcomers.push({ name: r[1], pos: r[0] });
    }
  });

  const gainHtml = gainers.map(m => `
    <div class="mov-row">
      <div class="mov-name">${m.name}</div>
      <div class="mov-change">
        ${m.from} → ${m.to}
        <strong>↑${m.delta}</strong>
      </div>
    </div>
  `).join('');

  const lossHtml = losers.map(m => `
    <div class="mov-row">
      <div class="mov-name">${m.name}</div>
      <div class="mov-change">
        ${m.from} → ${m.to}
        <strong>↓${Math.abs(m.delta)}</strong>
      </div>
    </div>
  `).join('');

  const newHtml = newcomers.slice(0, 12).map(n => `
    <div class="mov-row">
      <div class="mov-name">${n.name}</div>
      <div class="mov-change"><strong style="color:var(--gold-deep)">#${n.pos}</strong></div>
    </div>
  `).join('');

  area.innerHTML = `
    <div class="anim">
      <p style="color:var(--ink-mute); font-size:13px; margin-bottom:18px; max-width:680px; line-height:1.5; font-family:'Fraunces',serif; font-style:italic;">
        Mayores subidas y caídas en posición del ranking general entre ediciones, y empresas que <strong style="color:var(--ink); font-style:normal;">debutan</strong> en 2026 sin haber estado en 2024 ni 2025.
      </p>
      <div class="movement-grid">
        <div class="mov-col gain">
          <h3>Mayores <em>subidas</em></h3>
          ${gainHtml || '<div class="mov-row"><div class="mov-name" style="color:var(--ink-mute)">Sin datos suficientes</div></div>'}
        </div>
        <div class="mov-col loss">
          <h3>Mayores <em>caídas</em></h3>
          ${lossHtml || '<div class="mov-row"><div class="mov-name" style="color:var(--ink-mute)">Sin datos suficientes</div></div>'}
        </div>
      </div>
      <h3 style="font-family:'Fraunces',serif; font-size:18px; margin:32px 0 14px; color:var(--ink);">Debutantes en <em style="color:var(--gold-deep); font-style:normal;">2026</em> <span style="font-size:13px; color:var(--ink-mute); font-style:italic; font-weight:400;">(no estuvieron en 2024 ni 2025)</span></h3>
      <div class="movement-grid">
        <div>${newHtml}</div>
      </div>
    </div>
  `;
}

// ========================================
// EVOLUTION
// ========================================
function renderEvolution() {
  const indicators = [
    { key: 'cti_pct', label: '% ventas en CTI', unit: '%' },
    { key: 'people', label: 'Personas en innovación', unit: '' },
    { key: 'projects_count', label: 'Proyectos de innovación', unit: '' }
  ];
  const html = indicators.map(ind => {
    const vals = [2024, 2025, 2026].map(y => ({ y, v: DATA[y][ind.key] }));
    const max = Math.max(...vals.map(v => v.v));
    const bars = vals.map(v => {
      const h = (v.v / max) * 100;
      const display = ind.unit === '%' ? v.v + '%' : v.v.toLocaleString('es-CO');
      return `
        <div class="evo-bar">
          <span class="val">${display}</span>
          <div class="bar" style="height:${h}%"></div>
          <span class="yr">${v.y}</span>
        </div>
      `;
    }).join('');
    return `
      <div class="evo-card">
        <h4>${ind.label}</h4>
        <div class="evo-bars">${bars}</div>
      </div>
    `;
  }).join('');
  document.getElementById('evo-grid').innerHTML = html;
}

