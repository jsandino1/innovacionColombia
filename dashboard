function renderProjectCard(empresaName) {
  const d = DATA[state.year];
  const proj = d.projects[empresaName];
  const card = document.getElementById('proj-card');
  if (!proj) return;

  // find position
  let pos = '—', arq = '—';
  const gPos = d.general.findIndex(r => r[1] === empresaName);
  if (gPos !== -1) pos = `#${gPos + 1}`;
  ['inventor', 'rebelde', 'visionario', 'heroe'].forEach(a => {
    if (d[a]) {
      const p = d[a].findIndex(r => r[1] === empresaName);
      if (p !== -1) arq = `${a.charAt(0).toUpperCase()+a.slice(1)} · #${p+1}`;
    }
  });

  card.innerHTML = `
    <div class="anim">
      <div class="proj-eyebrow">Empresa destacada · ${state.year}</div>
      <div class="proj-company">${empresaName}</div>
      <div class="proj-stats">
        <div class="proj-stat">
          <div class="proj-stat-label">Pos. general</div>
          <div class="proj-stat-val">${pos}</div>
        </div>
        <div class="proj-stat">
